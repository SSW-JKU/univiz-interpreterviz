[
  {
    "code": "program Test

	class Inner {
		int i;
		char[] a;
		char ch;
	}

	int ii, jj;
	int[] arr;
	char a, b;
	char[] arr2;

	final int const1 = 3;
	final char const2 = 'w';
{
	int Func (int i) { return i*2; }

	void Math ()
		int i, j, k, l, m;
		Inner in;
		Inner[] arr;
	{
