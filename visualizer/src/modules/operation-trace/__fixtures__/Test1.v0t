source
program Test
	int v1;
	int v2;
	int v3;

	final int const1 = 3;
	final char const2 = 'w';
{
    int fun(int i) {
        return i * 2;
    }

	void main () {
		v1 = const1;
		v1++;

		v2 = fun(v1);

		v3 = v1 + v2;

		print(v3);
	}
}
